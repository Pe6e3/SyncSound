# Публичное имя хоста (как в браузере), для Let's Encrypt и server_name в nginx.
# Для кириллического домена антон.su используйте Punycode:
# антон.su -> xn--80a0aadt.su
DOMAIN=xn--80a0aadt.su

# Почта для регистрации ACME (Let's Encrypt).
EMAIL=you@example.com

# Только для отладки: STAGING=1 в .env даёт тестовые сертификаты (не для продакшена).
# STAGING=0
